generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id        String   @id @default(cuid())
  name      String

  logoUrl   String?   // 👈 NUEVO (Cloudinary URL)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  patients  Patient[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?

  role      String   @default("DOCTOR")

  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  accounts  Account[]
  sessions  Session[]

  isBlocked Boolean @default(false)

  stripeCustomerId   String? @unique
  stripeSubId        String? @unique
  subscriptionStatus String  @default("inactive")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clinicId])
}

model Patient {
  id        String   @id @default(cuid())

  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])

  firstName String
  lastName  String?

  birthDate DateTime?
  gender    String?

  phone     String?
  email     String?

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultations Consultation[]
  treatments    Treatment[]
  photos        Photo[]
  metrics       HairMetric[]
  transplants   TransplantProcedure[]

  @@index([clinicId])
}

model Consultation {
  id        String   @id @default(cuid())

  clinicId  String

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  date      DateTime @default(now())

  norwoodLevel Int?

  notes     String?

  createdAt DateTime @default(now())

  photos    Photo[]
  metrics   HairMetric[]

  @@index([clinicId])
}

model HairMetric {
  id        String   @id @default(cuid())

  clinicId  String

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  zone      String?

  density   Float?
  thickness Float?

  notes     String?

  createdAt DateTime @default(now())

  @@index([clinicId])
}

model Photo {
  id        String   @id @default(cuid())

  clinicId  String

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  consultationId String?
  consultation   Consultation? @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  url       String

  zone      String?
  notes     String?

  createdAt DateTime @default(now())

  @@index([clinicId])
}

model Treatment {
  id        String   @id @default(cuid())

  clinicId  String

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  medication String

  dosage     String?
  frequency  String?

  startDate  DateTime?
  endDate    DateTime?

  notes      String?

  createdAt DateTime @default(now())

  @@index([clinicId])
}

model TransplantProcedure {
  id        String   @id @default(cuid())

  clinicId  String

  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  date      DateTime

  technique String?
  method    String?

  grafts    Int?

  donorArea     String?
  recipientArea String?

  notes     String?

  anesthesiaType String?
  anesthesiaMl   Float?

  extractionStart   DateTime?
  extractionEnd     DateTime?

  implantationStart DateTime?
  implantationEnd   DateTime?

  observations String?
  medicalTeam  String?
  nurses       String?

  createdAt DateTime @default(now())

  blocks ProcedureBlock[]

  @@index([clinicId])
}

model ProcedureBlock {
  id String @id @default(cuid())

  procedureId String
  procedure   TransplantProcedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)

  blockNumber Int
  rowIndex    Int

  enf1 String?
  enf2 String?

  uf        Int?
  follicles Int?

  createdAt DateTime @default(now())

  @@index([procedureId])
}

/*
AUTH MODELS
*/

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique

  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}